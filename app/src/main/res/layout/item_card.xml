<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <org.osmdroid.views.MapView
            android:id="@+id/mapItem"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Vista transparente para capturar el clic encima del mapa -->
        <View
            android:id="@+id/mapClickOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="@id/mapItem"
            app:layout_constraintBottom_toBottomOf="@id/mapItem"
            app:layout_constraintStart_toStartOf="@id/mapItem"
            app:layout_constraintEnd_toEndOf="@id/mapItem" />

        <TextView
            android:id="@+id/txtItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/mapItem"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Nombre Actividad" />

        <!-- Columna de datos (Izquierda) -->
        <TextView
            android:id="@+id/txtDistanciaItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@+id/mapItem"
            app:layout_constraintTop_toBottomOf="@+id/txtItem"
            tools:text="5.20 km" />

        <TextView
            android:id="@+id/txtTiempoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@+id/mapItem"
            app:layout_constraintTop_toBottomOf="@+id/txtDistanciaItem"
            tools:text="01:30" />

        <!-- Descripción (Derecha) -->
        <TextView
            android:id="@+id/txtDescripcionItem"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="4dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textSize="12sp"
            android:textColor="#757575"
            app:layout_constraintBottom_toBottomOf="@+id/txtTiempoItem"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/txtDistanciaItem"
            app:layout_constraintTop_toTopOf="@+id/txtDistanciaItem"
            tools:text="Esta es una descripción breve de la actividad..." />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>